-- ==========================================
-- LÓGICA DEL MOTOR DE SALTO (EL CEREBRO)
-- ==========================================
local function SaltoMortal()
    StatusText.Text = "Buscando servidor limpio..."
    if httprequest then
        local url = "https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Desc&limit=100"
        local success, response = pcall(function() return httprequest({Url = url, Method = "GET"}) end)

        if success and response and response.Body then
            local data = HttpService:JSONDecode(response.Body)
            if data and data.data then
                for _, server in pairs(data.data) do
                    -- EL FILTRO MAESTRO: Que no sea tu server, que haya espacio, y QUE NO ESTÉ EN LA BLACKLIST
                    if type(server) == "table" and server.id ~= game.JobId and server.playing < server.maxPlayers then
                        if not estaEnBlacklist(server.id) then
                            StatusText.Text = "¡Saltando a: " .. server.id:sub(1,6) .. "...!"
                            TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                            return
                        end
                    end
                end
            end
        end
    end
    -- Si falla o todos están en blacklist, salta aleatorio
    TeleportService:Teleport(game.PlaceId, LocalPlayer)
end

local function EscanearServidor()
    StatusText.Text = "Escaneando mapa..."
    local encontrado = false
    local cualPayaso = ""

    for _, objeto in pairs(Workspace:GetDescendants()) do
        if objeto:IsA("Model") or objeto:IsA("Part") then
            for _, nombreVIP in pairs(NombresObjetivo) do
                if string.find(string.lower(objeto.Name), string.lower(nombreVIP)) then
                    encontrado = true
                    cualPayaso = nombreVIP
                    break
                end
            end
        end
        if encontrado then break end
    end

    if encontrado then
        -- ¡BINGO! Apaga el hopper
        writefile(archivoEstado, "OFF")
        ToggleBtn.Text = "DETENIDO"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        StatusText.Text = "¡SERVIDOR MILLONARIO!\nEncontrado: " .. cualPayaso .. " 🤑"
        StatusText.TextColor3 = Color3.fromRGB(255, 255, 0)
    else
        -- Servidor basura. Lo mete a la blacklist y salta.
        StatusText.Text = "Servidor Pobre. Metiendo a Blacklist..."
        StatusText.TextColor3 = Color3.fromRGB(255, 50, 50)
        agregarABlacklist(game.JobId)
        wait(0.5) -- Pausa pequeñita para no crashear el celular
        SaltoMortal()
    end
end

