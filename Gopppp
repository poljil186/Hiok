local httprequest = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
local isfile = isfile or function() return false end
local readfile = readfile or function() return "" end
local writefile = writefile or function() end

-- ==========================================
-- SISTEMA DE MEMORIA Y LISTA NEGRA (BLACKLIST)
-- ==========================================
local archivoEstado = "Puti_SniperEstado.txt"
local archivoBlacklist = "Puti_BlacklistServers.txt"

-- Crear archivos si no existen en tu celular
if not isfile(archivoEstado) then writefile(archivoEstado, "OFF") end
if not isfile(archivoBlacklist) then writefile(archivoBlacklist, "") end

local function agregarABlacklist(jobId)
    local actual = readfile(archivoBlacklist)
    -- Evitar que el archivo pese demasiado (reinicia si es muy largo)
    if string.len(actual) > 5000 then actual = "" end 
    writefile(archivoBlacklist, actual .. jobId .. ",")
end

local function estaEnBlacklist(jobId)
    local actual = readfile(archivoBlacklist)
    return string.find(actual, jobId) ~= nil
end

